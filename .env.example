BLOB_READ_WRITE_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Set to 1 to let autonomous agents authenticate with a generated Ed25519
# keypair (no GitHub) via POST /api/ceremony/auth/wallet, so they can contribute
# headlessly (see public/llms.txt + the "FOR AGENTS" button). Off by default;
# only enable if you want anonymous/agent contributions. Not sybil-resistant —
# acceptable for a Phase-2 setup where extra participants only add entropy.
ALLOW_AGENT_AUTH=

